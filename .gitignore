# ─── Secrets (never commit real values) ──────────────────────────────────────
.env
vps-bridge/.env
config/.secret_key
config/daemon_state.json
config/knowledge.db

# Auth profiles contain runtime API keys — generated by ZeroClaw at first login
# The committed version has placeholder ${OPENROUTER_API_KEY}
# config/auth-profiles.json  ← tracked with placeholder, do not ignore

# OTP secret — instance-specific, regenerated at runtime
# config/otp-secret          ← tracked with placeholder, do not ignore

# Backup files from VPS (contain real secrets)
config/*.bak*
config/*.backup*
config/*.broken*
config/*.bak-*

# ─── Binary ──────────────────────────────────────────────────────────────────
# The ZeroClaw binary is Linux x86_64 (38MB) — use Git LFS or download separately
bin/zeroclaw

# ─── Runtime state (generated, changes constantly) ───────────────────────────
runtime/memory/*.db-*
runtime/sessions/*.db-*
runtime/state/
runtime/cron/*.db*

# ─── Node modules ────────────────────────────────────────────────────────────
vps-bridge/node_modules/

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
vps-bridge/logs/

# ─── OS ──────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Skills repo (downloaded separately, not tracked here) ───────────────────
skills/

# SQLite runtime databases
runtime/memory/*.db
runtime/sessions/*.db
runtime/memory/*.db-shm
runtime/memory/*.db-wal
runtime/sessions/*.db-shm
runtime/sessions/*.db-wal
